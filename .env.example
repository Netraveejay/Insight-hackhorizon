# Insight production environment — copy to .env and edit before deploy
PORT=8080

# Security (REQUIRED for production)
AUTH_SECRET=generate-a-long-random-string-here

# Database — default SQLite in Docker volume; for Postgres use:
# DATABASE_URL=postgresql://insight:insight@db:5432/insight
DATABASE_URL=sqlite:////app/data/insight.db

# Paths (Docker defaults — usually leave as-is)
REPORTS_DIR=/app/data/reports
RULES_PATH=/app/rules/rules.v1.yaml

# Bootstrap demo data on first start (set false when using real feedback file)
AUTO_SEED=true

# Real feedback JSON export (same schema as seed data) — disables seed when file exists
# FEEDBACK_FILE_PATH=/app/data/inbound/feedback.json

# Microsoft Teams channel webhook — posts P1/P2 alerts (optional)
# TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# OpenAI for insight drafts (optional — template fallback works offline)
# OPENAI_API_KEY=sk-...

# CORS — set to your public URL if API and UI are on different origins
CORS_ORIGINS=http://localhost:8080

# Background pipeline schedule (every 30 min + weekly digest)
ENABLE_SCHEDULER=true

# Environment label
ENVIRONMENT=production
